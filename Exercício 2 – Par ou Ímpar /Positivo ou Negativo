programa
{
    funcao inicio()
    {
        inteiro numero

        escreva("Digite um número: ")
        leia(numero)

        se (numero % 2 == 0)
        {
            escreva("O Número ", numero, " é par ")
        }
        senao
        {
            escreva("O Número ", numero, " é ímpar ")
        }

        se (numero >= 0)
        {
            escreva("e positivo!")
        }
        senao
        {
            escreva("e negativo!")
        }
    }
}
